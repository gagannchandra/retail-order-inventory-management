# ========================

# Server Configuration

# ========================

PORT=10000
NODE_ENV=production

# ========================

# Database Configuration

# ========================

DB_HOST=your_database_host
DB_PORT=3306
DB_USER=your_database_user
DB_PASSWORD=your_database_password
DB_NAME=your_database_name

# ========================

# Authentication

# ========================

JWT_SECRET=your_super_secret_key
JWT_EXPIRES_IN=24h

# ========================

# Logging

# ========================

LOG_LEVEL=info
